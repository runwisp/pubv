{
  "name": "@runwisp/pubv",
  "version": "1.0.0",
  "description": "Automate releases from your Keep a Changelog CHANGELOG.md: bump the version, update the changelog, then commit, tag, and push in one command. A tiny, zero-config release CLI for GitHub, GitLab, and Bitbucket.",
  "type": "module",
  "bin": {
    "pubv": "dist/bin.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun build src/bin.ts --target=node --outfile=dist/bin.js --minify --banner=\"#!/usr/bin/env node\" && chmod +x dist/bin.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "changelog",
    "release",
    "release-automation",
    "release-tool",
    "release-cli",
    "release-management",
    "semver",
    "semantic-versioning",
    "version",
    "version-bump",
    "bump-version",
    "publish",
    "tag",
    "git-tag",
    "git",
    "keep-a-changelog",
    "changelog-generator",
    "automation",
    "devops",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runwisp/pubv.git"
  },
  "bugs": {
    "url": "https://github.com/runwisp/pubv/issues"
  },
  "homepage": "https://github.com/runwisp/pubv#readme",
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
