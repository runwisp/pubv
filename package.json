{
  "name": "pubv",
  "version": "0.0.0",
  "description": "Publish a new version: graduate the [Unreleased] block in CHANGELOG.md into a real release, commit, tag, and push.",
  "type": "module",
  "bin": {
    "pubv": "dist/bin.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun build src/bin.ts --target=node --outfile=dist/bin.js --minify --banner=\"#!/usr/bin/env node\" && chmod +x dist/bin.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "keywords": ["changelog", "release", "semver", "publish", "tag", "keep-a-changelog", "cli"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riki137/pubv.git"
  },
  "bugs": {
    "url": "https://github.com/riki137/pubv/issues"
  },
  "homepage": "https://github.com/riki137/pubv#readme",
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
